# Supabase (get from `npx supabase start` or Supabase Cloud dashboard)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ShortAPI
SHORTAPI_KEY=your-short-api-key

# Email (Resend) — run `npm i resend`. Domain must be verified in Resend.
RESEND_API_KEY=re_your-resend-key
EMAIL_FROM=Paixão <hello@paixao.ca>

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Paixão

# Founding pre-sale (one-time payment — no Stripe product needed, uses inline price_data)
# Escalating tiers in cents: 1–100 → CA$39, 101–200 → CA$139, 201–300 → CA$499, then closed.
FOUNDING_PRICE_1=3900
FOUNDING_PRICE_2=13900
FOUNDING_PRICE_3=49900
FOUNDING_CURRENCY=cad

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key
STRIPE_PRICE_DESIRE_MONTHLY=price_desire_monthly_id
STRIPE_PRICE_DESIRE_YEARLY=price_desire_yearly_id
STRIPE_PRICE_OBSESSION_MONTHLY=price_obsession_monthly_id
STRIPE_PRICE_OBSESSION_YEARLY=price_obsession_yearly_id
STRIPE_PRICE_PATRON_MONTHLY=price_patron_monthly_id
STRIPE_PRICE_PATRON_YEARLY=price_patron_yearly_id

# Analytics (optional, vendor-agnostic — leave blank to console-log in dev only)
# Configure EITHER PostHog OR Plausible. If both are set, PostHog wins.
# PostHog
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Plausible
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_PLAUSIBLE_SRC=https://plausible.io/js/script.js
